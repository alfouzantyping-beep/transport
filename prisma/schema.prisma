generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Status {
  ACTIVE
  INACTIVE
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  MAINTENANCE
  INACTIVE
}

enum VehicleType {
  TRUCK
  TRAILER
  TANKER
  FLATBED
  REEFER
  WATER_TANKER
  OTHER
}

enum OwnerType {
  COMPANY_OWNED
  RENTED
  THIRD_PARTY
}

enum ExpenseCategoryType {
  TRIP
  VEHICLE
  DRIVER
  GENERAL
}

enum OperationTripStatus {
  OPEN
  ON_TRIP
  COMPLETED
  CLOSED
  INVOICED
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  OTHER
}

enum SettlementResultType {
  DRIVER_OWES_COMPANY
  COMPANY_OWES_DRIVER
  SETTLED
}

enum SettlementStatus {
  PENDING
  SETTLED
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

model User {
  id           String   @id @default(uuid())
  name         String   @default("")
  username     String   @unique
  email        String   @unique
  password     String   @default("")
  passwordHash String   @default("")
  role         String   @default("Operations")
  roleId       String?
  status       Status   @default(ACTIVE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  roleRef     Role?         @relation(fields: [roleId], references: [id])
  closedTrips TripClosing[]
}

model Company {
  id             String   @id @default(uuid())
  companyName    String
  tradeLicenseNo String
  trn            String
  address        String
  phone          String
  email          String
  website        String?
  logoUrl        String?
  bankName       String?
  iban           String?
  accountNo      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CompanyProfile {
  id      Int     @id @default(1)
  name    String
  license String
  trn     String
  address String
  phone   String
  email   String
  logoUrl String?
}

model Customer {
  id            String   @id @default(uuid())
  companyName   String   @default("")
  name          String
  contactPerson String
  phone         String
  email         String
  address       String
  trn           String
  paymentTerms  String
  creditLimit   Float    @default(0)
  status        Status   @default(ACTIVE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  trips    Trip[]
  payments Payment[]
}

model Driver {
  id             String    @id @default(uuid())
  name           String
  mobile         String
  passport       String    @default("")
  passportNo     String    @default("")
  emiratesId     String
  license        String    @default("")
  licenseNo      String    @default("")
  licenseExpiry  DateTime?
  visaExpiry     DateTime?
  salary         Float     @default(0)
  basicSalary    Float     @default(0)
  advanceBalance Float     @default(0)
  visaBalance    Float     @default(0)
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  trucks   Truck[]
  vehicles Vehicle[]
  trips    Trip[]
  salaries Salary[]
  cashAdvances DriverCashAdvance[]
  expenses TripExpense[]
  settlements TripSettlement[]
}

model Vehicle {
  id                 String        @id @default(uuid())
  truckNo            String        @unique
  plateNo            String        @unique
  trailerNo          String?
  vehicleType        VehicleType   @default(TRUCK)
  model              String?
  ownerType          OwnerType     @default(COMPANY_OWNED)
  registrationExpiry DateTime
  insuranceExpiry    DateTime
  currentDriverId    String?
  status             VehicleStatus @default(AVAILABLE)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  currentDriver Driver? @relation(fields: [currentDriverId], references: [id])
  trips Trip[]
  expenses TripExpense[]
}

model ExpenseCategory {
  id          String              @id @default(uuid())
  name        String              @unique
  type        ExpenseCategoryType @default(TRIP)
  description String?
  status      Status              @default(ACTIVE)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  expenses TripExpense[]
}

model Truck {
  id                 String   @id @default(uuid())
  truckNumber        String   @unique
  plateNumber        String
  trailerNumber      String
  type               String
  registrationExpiry DateTime
  insuranceExpiry    DateTime
  status             String   @default("AVAILABLE")
  assignedDriverId   String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  assignedDriver Driver?            @relation(fields: [assignedDriverId], references: [id])
  trips          Trip[]
  maintenances   TruckMaintenance[]
}

enum TripStatus {
  OPEN
  ON_TRIP
  COMPLETED
  CLOSED
  INVOICED
  LOADING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model Trip {
  id            String     @id @default(uuid())
  tripNo        String?    @unique
  tripDate      DateTime   @default(now())
  tripNumber    String     @unique
  customerId    String
  driverId      String
  truckId       String
  vehicleId     String?
  fromCountry   String
  toCountry     String
  loadingPoint  String
  deliveryPoint String
  doNumber      String
  cargoType     String
  cargoWeight   Float      @default(0)
  tripAmount    Float
  status        TripStatus @default(OPEN)
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  customer   Customer       @relation(fields: [customerId], references: [id])
  driver     Driver         @relation(fields: [driverId], references: [id])
  truck      Truck          @relation(fields: [truckId], references: [id])
  vehicle    Vehicle?       @relation(fields: [vehicleId], references: [id])
  driverCash DriverCash[]
  cashAdvances DriverCashAdvance[]
  expenses   TripExpense[]
  closing    TripClosing?
  settlement TripSettlement?
  invoice    Invoice?
}

enum CashMethod {
  CASH
  BANK_TRANSFER
  CARD
}

model DriverCash {
  id            String     @id @default(uuid())
  tripId        String
  amount        Float
  date          DateTime
  paymentMethod CashMethod @default(CASH)
  notes         String?
  createdAt     DateTime   @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model DriverCashAdvance {
  id            String        @id @default(uuid())
  tripId        String
  driverId      String
  amount        Float
  cashDate      DateTime
  paymentMethod PaymentMethod @default(CASH)
  givenBy       String
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  driver Driver @relation(fields: [driverId], references: [id])
}

model TripExpense {
  id           String   @id @default(uuid())
  tripId       String
  driverId     String?
  vehicleId    String?
  expenseCategoryId String?
  expenseDate  DateTime @default(now())
  receiptNo    String?
  amount       Float    @default(0)
  pettyCash    Float    @default(0)
  usedPettyCash Float   @default(0)
  remainingBalance Float @default(0)
  description  String?
  receiptImageUrl String?
  diesel       Float    @default(0)
  petrol       Float    @default(0)
  toll         Float    @default(0)
  border       Float    @default(0)
  visa         Float    @default(0)
  customs      Float    @default(0)
  food         Float    @default(0)
  parking      Float    @default(0)
  maintenance  Float    @default(0)
  hotel        Float    @default(0)
  other        Float    @default(0)
  qatarVisa    Float    @default(0)
  qatarToll    Float    @default(0)
  ksaVisa      Float    @default(0)
  uaeCustoms   Float    @default(0)
  ksaCustoms   Float    @default(0)
  mezan        Float    @default(0)
  jordanBorder Float    @default(0)
  cameraFine   Float    @default(0)
  hayaPeshgi   Float    @default(0)
  gatePass     Float    @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  driver Driver? @relation(fields: [driverId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  expenseCategory ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id])
}

model TripSettlement {
  id                String               @id @default(uuid())
  tripId            String               @unique
  driverId          String
  totalCashGiven    Float
  totalExpenses     Float
  settlementBalance Float
  resultType        SettlementResultType
  status            SettlementStatus     @default(PENDING)
  settlementDate    DateTime?
  notes             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  driver Driver @relation(fields: [driverId], references: [id])
}

model TripClosing {
  id               String   @id @default(uuid())
  tripId           String   @unique
  totalCashGiven   Float
  totalExpenses    Float
  remainingBalance Float
  extraPayable     Float
  closedDate       DateTime @default(now())
  closedById       String

  trip     Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  closedBy User @relation(fields: [closedById], references: [id])
}

enum InvoiceStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  tripId        String        @unique
  invoiceDate   DateTime
  dueDate       DateTime
  amount        Float
  vatAmount     Float         @default(0)
  totalAmount   Float
  paidAmount    Float         @default(0)
  pendingAmount Float
  status        InvoiceStatus @default(UNPAID)
  createdAt     DateTime      @default(now())

  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  payments Payment[]
}

model Payment {
  id              String   @id @default(uuid())
  customerId      String
  invoiceId       String?
  amount          Float
  paymentDate     DateTime
  paymentMethod   String
  referenceNumber String?
  notes           String?
  createdAt       DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
  invoice  Invoice? @relation(fields: [invoiceId], references: [id])
}

model TruckMaintenance {
  id           String   @id @default(uuid())
  truckId      String
  date         DateTime
  oilChange    Float    @default(0)
  tyre         Float    @default(0)
  battery      Float    @default(0)
  engineRepair Float    @default(0)
  brakeRepair  Float    @default(0)
  service      Float    @default(0)
  passing      Float    @default(0)
  insurance    Float    @default(0)
  amount       Float
  workshop     String
  notes        String?
  createdAt    DateTime @default(now())

  truck Truck @relation(fields: [truckId], references: [id], onDelete: Cascade)
}

model Salary {
  id               String   @id @default(uuid())
  driverId         String
  month            Int
  year             Int
  baseSalary       Float
  advanceDeduction Float    @default(0)
  fineDeduction    Float    @default(0)
  visaDeduction    Float    @default(0)
  roomDeduction    Float    @default(0)
  netSalary        Float
  paymentDate      DateTime
  notes            String?
  createdAt        DateTime @default(now())

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
}
